"""Snakemake workflow: generate cdot paper via vibepaper.

Quickstart — build paper using existing facts CSVs (run from project root):
    snakemake -s paper/Snakefile --cores 1

Recompute coverage/benchmark from production data, then build:
    snakemake -s paper/Snakefile --cores 1 --config data_dir=/path/to/cdot/data

Recompute one facts file:
    snakemake -s paper/Snakefile --cores 1 output/facts/coverage.csv

Config keys (via --config or a config.yaml):
    data_dir         Directory with production JSON.gz files.
    clinvar_hgvs_csv Path to ClinVar HGVS benchmark CSV.
    uta_uri          PostgreSQL URI for UTA, e.g. postgresql://uta_admin@localhost/uta/uta_20210129
"""

from pathlib import Path

# ---------------------------------------------------------------------------
# Resolve config
# ---------------------------------------------------------------------------

DATA_DIR    = config.get("data_dir", "")
CLINVAR_CSV = config.get("clinvar_hgvs_csv", "")

def data_file(stem):
    """Return path from explicit config or data_dir/<stem>, else empty string."""
    if stem in config:
        return config[stem]
    if DATA_DIR:
        return str(Path(DATA_DIR) / stem)
    return ""

FILES = {
    "refseq_grch37":  data_file("cdot.refseq.grch37.json.gz"),
    "refseq_grch38":  data_file("cdot.refseq.grch38.json.gz"),
    "refseq_t2t":     data_file("cdot.refseq.t2t.json.gz"),
    "ensembl_grch37": data_file("cdot.ensembl.grch37.json.gz"),
    "ensembl_grch38": data_file("cdot.ensembl.grch38.json.gz"),
}

HAVE_DATA    = any(p and Path(p).exists() for p in FILES.values())
HAVE_CLINVAR = bool(CLINVAR_CSV and Path(CLINVAR_CSV).exists())

PYTHON = ".venv/bin/python"
VIBE   = ".venv/bin/vibepaper build --config paper/paper.toml"

# The render always reads facts from GEN_FACTS (= paper.toml facts_dir = output/facts).
# How GEN_FACTS gets populated is the only difference between the two build modes:
#   FULL  - regenerate the facts there from production data / benchmark runs.
#   QUICK - copy the committed stored results from EMPIRICAL into there.
# EMPIRICAL is the checked-in snapshot of measured results (NOT "facts" - those are
# the generated templating values); `full` refreshes it after a successful run.
EMPIRICAL  = "paper/empirical_results"
GEN_FACTS  = "output/facts"
FACT_FILES = ["literature.csv", "coverage.csv", "benchmark.csv",
              "clinvar.csv", "cleaning.csv", "sources.csv"]

PAPER_SOURCES = [
    "paper/abstract.md",
    "paper/introduction.md",
    "paper/methods.md",
    "paper/results.md",
    "paper/discussion.md",
    "paper/figures.md",
    "paper/supplementary.md",
    "paper/references.bib",
    "paper/bioinformatics.csl",
    "paper/paper.toml",
]

# ---------------------------------------------------------------------------
# Rules
# ---------------------------------------------------------------------------

rule all:
    """Default target: the fast (quick) build."""
    input: "output/.paper_built_quick"


rule quick:
    """QUICK build: copy the committed stored results from paper/empirical_results/
    into the facts dir (output/facts/), then render - exactly where a real benchmark
    run would write them, so the render path is identical. No production data, no
    private corpus, no network. Seconds. This is the default."""
    input:
        sources  = PAPER_SOURCES,
        stored   = [f"{EMPIRICAL}/{f}" for f in FACT_FILES],
    output:
        touch("output/.paper_built_quick"),
    shell:
        "mkdir -p {GEN_FACTS} && cp {EMPIRICAL}/*.csv {GEN_FACTS}/ && {VIBE}"


rule full:
    """FULL build: regenerate every fact into output/facts/ from scratch, render,
    then refresh the committed paper/empirical_results/ snapshot. Reproducible facts
    (coverage, ClinVar resolution, throughput, cleaning injection, sources) are
    recomputed - several need --config data_dir=... (and clinvar_hgvs_csv=...,
    uta_uri=...). The Tier-2 cleaning constants (production rescue rates + residual
    taxonomy in results.md) come from the private cdot_private corpus and are
    transcribed by hand; see paper/README.md. Slow (the full-ClinVar throughput
    runs take ~1.5 h each)."""
    input:
        sources = PAPER_SOURCES,
        facts   = [f"{GEN_FACTS}/{f}" for f in FACT_FILES],
    output:
        touch("output/.paper_built_full"),
    shell:
        # render from the freshly regenerated facts; only refresh the committed
        # snapshot once the render succeeds, so a botched run can't corrupt it
        "{VIBE} && cp {GEN_FACTS}/*.csv {EMPIRICAL}/"


rule literature:
    """Write static literature facts (values from published papers)."""
    output: "output/facts/literature.csv"
    run:
        import csv, os
        os.makedirs("output/facts", exist_ok=True)
        rows = [{
            "clinvar_variants":     3000000,
            "hgvs_error_rate_pct":  50,
            "lof_agreement_pct":    44,
            "brca2_accuracy_pct":   32,
            "uta_count":            141000,
            "uta_remote_tps":       1,
            "mane_coverage_pct":    97,
            "seqrepo_speedup_fold": 1300,
        }]
        with open(output[0], "w", newline="") as fh:
            writer = csv.DictWriter(fh, fieldnames=list(rows[0]))
            writer.writeheader()
            writer.writerows(rows)
        print(f"Written: {output[0]}")


rule coverage:
    """Compute transcript coverage from production JSON.gz files.

    Requires --config data_dir=/path/to/data (or individual file paths).
    Without data, writes placeholder zeros so the paper build still runs.
    """
    output: "output/facts/coverage.csv"
    run:
        import os
        os.makedirs("output/facts", exist_ok=True)
        if not HAVE_DATA:
            print("WARNING: no data_dir set — writing placeholder zeros to coverage.csv")
            print("  Run with --config data_dir=/path/to/data to compute real values.")
            import csv
            row = {k: 0 for k in [
                "total_count", "refseq_grch37_count", "refseq_grch38_count",
                "t2t_count", "ensembl_grch37_count", "ensembl_grch38_count",
                "ensembl_unique_count", "t2t_unique_count", "improvement_fold",
            ]}
            with open(output[0], "w", newline="") as fh:
                writer = csv.DictWriter(fh, fieldnames=list(row))
                writer.writeheader()
                writer.writerow(row)
        else:
            flags = " ".join(
                f"--{name.replace('_', '-')} {path}"
                for name, path in FILES.items()
                if path and Path(path).exists()
            )
            shell(f"{PYTHON} analysis/compute_coverage.py {flags}")


rule benchmark:
    """Benchmark local JSON throughput and load time.

    Requires --config data_dir=/path/to/data pointing to a GRCh38 RefSeq JSON.gz.
    Without data, writes the measured throughput facts below (HGVS/s, GRCh38 RefSeq,
    identical biocommons engine + shared local SeqRepo; see analysis/benchmark_resolution.py
    and analysis/compare_providers.py). These are frozen measurements, not placeholders.
    """
    output: "output/facts/benchmark.csv"
    run:
        import os, csv
        os.makedirs("output/facts", exist_ok=True)
        grch38 = FILES.get("refseq_grch38", "")
        if grch38 and Path(grch38).exists():
            uta_flag = f"--uta-uri {config['uta_uri']}" if "uta_uri" in config else ""
            shell(f"{PYTHON} analysis/compute_benchmark.py --refseq-grch38 {grch38} {uta_flag}")
        else:
            print("No data_dir — writing the frozen measured benchmark facts to benchmark.csv")
            # Measured HGVS/s (GRCh38 RefSeq, biocommons engine, shared local SeqRepo):
            # local JSON 540 (500-set) -> 665 (full 3.66M ClinVar); REST 39 cold, 731 after a
            # batch prefetch; local UTA 24; public remote UTA 0.1. See R5 / Table 2.
            row = {
                "cdot_local_min_tps":      540,
                "cdot_local_max_tps":      665,
                "cdot_rest_tps":           39,
                "cdot_rest_prefetch_tps":  731,
                "uta_local_tps":           24,
                "uta_remote_tps":          0.1,
                "grch38_load_time_s":      10.6,
            }
            with open(output[0], "w", newline="") as fh:
                writer = csv.DictWriter(fh, fieldnames=list(row))
                writer.writeheader()
                writer.writerow(row)


rule clinvar:
    """Resolve ClinVar HGVS variants and write resolution rates.

    Requires --config clinvar_hgvs_csv=/path/to/clinvar.csv.
    Without data, writes placeholder zeros.
    """
    output: "output/facts/clinvar.csv"
    run:
        import os, csv
        os.makedirs("output/facts", exist_ok=True)
        if HAVE_CLINVAR:
            shell(f"{PYTHON} analysis/investigate_fails.py {CLINVAR_CSV}")
        else:
            print("WARNING: no clinvar_hgvs_csv configured — writing placeholder zeros to clinvar.csv")
            print("  Run with --config clinvar_hgvs_csv=/path/to/file to compute real values.")
            row = {"n_variants": 0, "cdot_resolution_pct": 0.0, "uta_resolution_pct": 0.0}
            with open(output[0], "w", newline="") as fh:
                writer = csv.DictWriter(fh, fieldnames=list(row))
                writer.writeheader()
                writer.writerow(row)


rule cleaning:
    """Tier-1 reproducible injection cleaning benchmark (issue #112).

    Runs on public ClinVar c.HGVS committed to this repo (no data_dir needed).
    Writes both the rich fact JSON and the single-row cleaning.csv used by the
    paper templates. The injection weights are frozen constants citing the
    aggregate production rescue-op distribution (Tier 2) — no corpus data is
    read; see analysis/inject_and_clean.py.
    """
    output: "output/facts/cleaning.csv"
    shell:
        "{PYTHON} analysis/inject_and_clean.py"


rule sources:
    """Count annotation releases ingested per consortium/build (the sources.*_releases
    facts in Methods) from generate_transcript_data/cdot_transcripts.yaml - the
    committed source list. No production data needed."""
    output: "output/facts/sources.csv"
    shell:
        "{PYTHON} analysis/compute_sources.py"
